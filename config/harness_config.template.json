// Commented template for config/harness_config.json.
// The runtime config must be strict JSON, so remove comments before copying.
{
  "schema_version": 2,

  // Unique id for the next manual experiment directory.
  // Change this before each repeated `uv run exp`.
  // `uv run auto` overwrites this for supervisor-launched candidates.
  "experiment_id": "exp-example",

  // Short label for the hypothesis or mechanism being tested.
  "focus_name": "short-mechanism-label",

  // Terminal-Bench 2 task ids:
  // https://www.tbench.ai/benchmarks/terminal-bench-2
  // Local task_overrides/<task_id> directories take precedence over the Harbor registry.
  // Start with one cheap smoke task; expand only after setup is working.
  "panels": [
    {
      "id": "train",
      "purpose": "promotion",
      "task_names": [
        "log-summary-date-ranges"
      ],

      // Wall-clock timeout for one train task trial.
      "task_timeout_sec": 300.0,
      "run": { "when": "always" },
      "baseline": { "required": false }
    }

    // Held-out tasks run only after the train panel passes promotion criteria.
    // They can block promotion on regression but cannot create promotion alone.
    // Add a comma after the train panel and uncomment this block to enable one.
    // ,
    // {
    //   "id": "test",
    //   "purpose": "regression_veto",
    //   "task_names": ["held-out-task-id"],
    //   "task_timeout_sec": 600.0,
    //   "run": { "after_panel": "train", "when_status": "keep" },
    //   "baseline": { "required": true }
    // }
  ],

  // Maximum policy/environment steps per task trial. Raise this for serious runs.
  "max_steps": 100,

  // Maximum task trials in flight (each holds one live container). Keep this at
  // 1 until Docker and API cost behavior is understood. Raise it above
  // max_heavy_action_concurrency to overlap trials that are idling on the LLM (LLM
  // requests are remote and absorb concurrency cheaply; the host CPU does not).
  "max_trial_concurrency": 1,

  // Maximum trials running heavyweight harness actions (reset/startup, run,
  // verify) at once. Cheap file/list/search/edit commands bypass this gate.
  // This is the host-CPU contention bound.
  //
  // Set it BELOW the host core count, not "near" it: heavy ops (compiles, ML
  // verifiers) are themselves multi-threaded, so N concurrent ops can demand far
  // more than N cores. Oversubscribing the cores slows every heavy op, which can
  // push long trials past task_timeout_sec and turn would-be solves into
  // timeouts. (A per-container `cpus` cap would bound this, but harbor declares
  // it under compose `deploy.resources.limits`, which `docker compose up`
  // ignores outside swarm, so containers currently run uncapped.)
  //
  // Interaction with max_trial_concurrency: this gate only binds once
  // max_trial_concurrency is high enough to keep it saturated (no effect when
  // >= max_trial_concurrency). So raising max_trial_concurrency for LLM-overlap
  // throughput is safe only while this stays low enough to keep concurrent heavy
  // ops under the core count. Default 10; ~half the cores is a safe start.
  "max_heavy_action_concurrency": 1,

  // Retries after invalid model tool/output formatting.
  "max_output_retries": 2,

  // Independent trials per task. Promotion decisions use majority outcomes.
  "task_trials": 1,

  "llm_provider_config": {
    // Supported providers: "openrouter" or experimental "chatgpt_codex".
    // For "chatgpt_codex", run `codex login` first and provide
    // "model_name" plus explicit "max_context_length".
    "provider": "openrouter",

    // OpenRouter model identifier.
    "model_name": "deepseek/deepseek-v4-flash",

    // Completion token cap requested from the provider.
    "max_output_tokens": 16384,

    // One of: "none", "low", "medium", "high".
    "reasoning_effort": "low",

    // Per-request LLM timeout.
    "timeout_seconds": 300.0,

    // OpenRouter-compatible API base URL.
    "base_url": "https://openrouter.ai/api/v1",

    // Optional sampling/provider fields:
    // "temperature": 0.0,
    // "top_p": 1.0,
    // "seed": 1,
    // "service_tier": "default",

    "provider_kwargs": {
      // Ask OpenRouter to reject providers that cannot honor requested params.
      "require_parameters": true,

      // OpenRouter provider routing used by the checked-in default.
      // Adjust this if the provider is unavailable in your OpenRouter account.
      "provider": {
        "order": ["gmicloud"],
        "allow_fallbacks": true,
        "ignore": [
          "siliconflow",
          "parasail",
          "morph",
          "venice"
        ]
      }
    }
  }
}
