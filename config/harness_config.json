    "provider_kwargs": {
      "require_parameters": true,
      "provider": {
        "order": [
          "gmicloud"
        ],
        "allow_fallbacks": true,
        "ignore": [
          "siliconflow",
          "parasail",
          "morph",
          "venice"
        ]
      }
    }
  }
