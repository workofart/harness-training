# Copy to `.env` and fill in your key. The .env file is gitignored.
# Required by configs whose llm_provider_config.api_key_env is OPENROUTER_API_KEY.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Required by configs whose api_key_env is LOCAL_LLM_API_KEY, including the
# quickstart. The client must send something even when the server ignores auth,
# so the placeholder below covers that case. Replace it with your server's real
# key if the server checks them, or it answers `401 Invalid API key`.
LOCAL_LLM_API_KEY=unused
